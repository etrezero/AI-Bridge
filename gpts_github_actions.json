{
  "openapi": "3.1.0",
  "info": {
    "title": "AI-Bridge GitHub API",
    "description": "GPTs와 로컬 DB/API를 연결하는 GitHub 브릿지. DB 쿼리 전 반드시 getDbSchema로 테이블/열 정보를 확인하세요. 주요 테이블: FDTFN001(펀드마스터), FDTFN201(일별NAV), DWPM10040(수익률), DWPM10530(보유종목)",
    "version": "2.2.0"
  },
  "servers": [{"url": "https://api.github.com"}],
  "paths": {
    "/repos/etrezero/AI-Bridge/contents/db_schema.json": {
      "get": {
        "operationId": "getDbSchema",
        "summary": "Get database schema reference (13 tables)",
        "description": "DB 쿼리 전 반드시 먼저 호출! 13개 테이블 정보 반환: FDTFN001(펀드마스터), FDTFN201(일별NAV/설정액), FDTPF301(포트폴리오), DWPM10040(수익률), DWPM10510(일별상세), DWPM10530(보유종목), DWPM11030(자금흐름), DWPI10011(펀드정보), DWPI10021(종목마스터), BB_TDF0JG, BMJISU, BB_EOD0IX, BB_HLDCLS. TDF펀드코드 매핑, 운용사코드, 예시쿼리 포함.",
        "responses": {"200": {"description": "DB schema (Base64 JSON) - tables, columns, example_queries, tdf_focus_fund_codes, company_codes, common_queries, join_patterns, filter_tips"}}
      }
    },
    "/repos/etrezero/AI-Bridge/contents/gpts_commands/{filename}": {
      "put": {
        "operationId": "createCommand",
        "summary": "Create command file",
        "description": "gpts_commands/에 JSON 명령 파일 생성. DB 쿼리 시 getDbSchema에서 확인한 테이블/컬럼명 사용.",
        "parameters": [{"name": "filename", "in": "path", "required": true, "schema": {"type": "string"}}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["message", "content"],
                "properties": {
                  "message": {"type": "string"},
                  "content": {"type": "string", "description": "Base64 encoded JSON. DB예시: {id,type:db_query,query:SELECT fund_cd,fund_fnm FROM FDTFN001 LIMIT 10}"},
                  "sha": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {"201": {"description": "Created"}}
      }
    },
    "/repos/etrezero/AI-Bridge/contents/gpts_results": {
      "get": {"operationId": "listResults", "summary": "List results", "responses": {"200": {"description": "Result files"}}}
    },
    "/repos/etrezero/AI-Bridge/contents/gpts_results/{filename}": {
      "get": {
        "operationId": "getResult",
        "summary": "Get result",
        "parameters": [{"name": "filename", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {"200": {"description": "Result content"}}
      }
    },
    "/repos/etrezero/AI-Bridge/contents/{path}": {
      "get": {
        "operationId": "getFileContent",
        "summary": "Get file content",
        "parameters": [{"name": "path", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {"200": {"description": "File content"}}
      }
    }
  },
  "components": {
    "schemas": {
      "CommandContent": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {"type": "string", "description": "Unique command ID (e.g., cmd_20260401_123456)"},
          "type": {"type": "string", "enum": ["db_query", "api_call"], "description": "Command type"},
          "query": {"type": "string", "description": "SQL query for db_query type"}
        }
      }
    },
    "securitySchemes": {"bearerAuth": {"type": "http", "scheme": "bearer"}}
  },
  "security": [{"bearerAuth": []}]
}
